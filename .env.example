# Temporal Server - IP ou hostname (sem porta, a porta 7233 é adicionada pelo código)
TEMPORAL_SERVER_IP=3.149.243.163

# Porta do MCP Server (HTTP/SSE) - default: 3100
MCP_PORT=3100

# Ambiente de Execução (production para filas de produção, qualquer outro para filas de teste)
# Omitir essa variável fará o sistema rodar com sufixo -teste por segurança.
NODE_ENV=development
